{
    "layer": "top",
    "position": "top",
    "height": 20, 
    "margin-top": 0,
    "spacing": 0,

    "modules-left": [],
    "modules-center": [
        "hyprland/workspaces",
        "custom/caffeine",
        "clock",
        "pulseaudio",
        "battery",
        "tray"
    ],
    "modules-right": [],

    "hyprland/workspaces": {
        "format": "{name}",
        "on-click": "activate"
    },

    "custom/caffeine": {
        "format": "{}",
        "exec": "if pgrep -x hypridle > /dev/null; then echo '󰈈 '; else echo '󰈉 '; fi",
        "interval": 2,
        "on-click": "~/.config/waybar/scripts/caffeine.sh"
    },

    "clock": {
        "interval": 1,
        "format": "󰃭 {:%d/%m   %H:%M:%S}",
        "tooltip-format": "<tt>{calendar}</tt>",
        "calendar": {
            "format": {
                "today": "<span color='#fAfBfC'><b>{}</b></span>"
            }
        },
        "actions": {
            "on-click-right": "shift_down",
            "on-click": "shift_up"
        }
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "󰝟",
        "format-icons": { "default": ["󰕿", "󰖀", "󰕾"] }
    },

    "battery": {
        "format": "{icon} {capacity}%",
        "format-icons": ["󰂎", "󰁺", "󰁹"]
    },

    "tray": { 
        "icon-size": 15, 
        "spacing": 8 
    }
}
